# Network Attack Visualiser — example environment configuration.
#
# Copy this file to `.env` at the repository root and adjust as needed:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must never be committed. This example contains only
# non-secret development defaults — no passwords, tokens, keys or secrets.
# Secret-bearing settings (for example a sensor ingest token) are introduced in
# the later phases that need them, never here.
#
# Phase 1 (backend skeleton) consumes only the variables below. Each value shown
# is the built-in default; every variable is optional and validated on load.

# Human-readable application name, surfaced as the API/OpenAPI title.
APP_NAME="Network Attack Visualiser"

# Version reported by GET /health and the OpenAPI schema. Defaults to the
# packaged application version; override only when you intend to.
APP_VERSION="0.3.0"

# Deployment environment: development | test | production.
ENVIRONMENT=development

# Host and port the development server binds to (loopback by default).
HOST=127.0.0.1
PORT=8000

# ---------------------------------------------------------------------------
# Detection engine (Phase 2)
#
# Initial laboratory defaults for the two heuristic detectors (see
# docs/DETECTION_RULES.md). All values are non-secret and configurable. The
# *_COOLDOWN_S values are consumed by the Phase 3 Alert Engine, not the detectors.
# ---------------------------------------------------------------------------

# portscan — distinct-destination-port detector.
PORTSCAN_WINDOW_S=10          # Sliding window length (seconds).
PORTSCAN_MIN_PORTS=15         # Distinct ports that trigger an alert.
PORTSCAN_CRITICAL_PORTS=100   # Fan-out at/above which severity is critical (> 2 x MIN_PORTS).
PORTSCAN_STATE_TTL_S=60       # Idle-key state expiry (seconds).
PORTSCAN_COOLDOWN_S=60        # Alert cooldown (seconds) — Phase 3.

# synflood — destination-centric SYN-flood / half-open detector.
SYN_WINDOW_S=5                # Sliding window length (seconds).
SYN_MIN_COUNT=100             # SYNs in-window required to consider a flood.
SYN_MAX_COMPLETION_RATIO=0.2  # Completion ratio below which traffic is suspicious.
HANDSHAKE_TTL_S=10            # Pending-entry (half-open) expiry (seconds).
SYN_STATE_TTL_S=30            # Idle-key state expiry (seconds).
SYN_COOLDOWN_S=60            # Alert cooldown (seconds) — consumed by the Alert Engine.

# ---------------------------------------------------------------------------
# Alert pipeline (Phase 3)
#
# Storage, ingest authentication/limits, browser CORS and the WebSocket feed
# (see docs/API.md and docs/SECURITY_REQUIREMENTS.md). Every value shown is the
# built-in default except SENSOR_TOKEN, which has NO default: without it the
# ingest endpoint fails closed with HTTP 503.
# ---------------------------------------------------------------------------

# SQLite database path (ephemeral lab data; git-ignored). ':memory:' is accepted.
DATABASE_PATH=data/nav.sqlite3

# Exact browser-origin allowlist for REST CORS and the WebSocket handshake,
# comma-separated. Wildcards are rejected on load.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Shared secret the sensor presents in X-Sensor-Token (minimum 16 characters).
# REQUIRED for ingest; keep it out of version control. Placeholder only:
#SENSOR_TOKEN=change-me-to-a-long-random-value

# Ingest limits, enforced before any event reaches a detector.
INGEST_MAX_BATCH=200            # Maximum events per ingest request (413 beyond).
INGEST_MAX_BODY_BYTES=262144    # Maximum request-body bytes, checked before parsing (413).
MAX_CLOCK_SKEW_S=300            # Maximum |ts - wall clock| for live events (seconds).

# Retention and delivery bounds.
ALERT_MAX_ROWS=10000            # Rolling cap on stored alert rows (oldest pruned).
WS_MAX_QUEUE=100                # Per-subscriber WebSocket queue; overflow disconnects (1013).

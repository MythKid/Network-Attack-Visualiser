# Network Attack Visualiser — example environment configuration.
#
# Copy this file to `.env` at the repository root and adjust as needed:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must never be committed. This example contains only
# non-secret development defaults — no passwords, tokens, keys or secrets.
# Secret-bearing settings (for example a sensor ingest token) are introduced in
# the later phases that need them, never here.
#
# Phase 1 (backend skeleton) consumes only the variables below. Each value shown
# is the built-in default; every variable is optional and validated on load.

# Human-readable application name, surfaced as the API/OpenAPI title.
APP_NAME="Network Attack Visualiser"

# Version reported by GET /health and the OpenAPI schema. Defaults to the
# packaged application version; override only when you intend to.
APP_VERSION="0.1.0"

# Deployment environment: development | test | production.
ENVIRONMENT=development

# Host and port the development server binds to (loopback by default).
HOST=127.0.0.1
PORT=8000

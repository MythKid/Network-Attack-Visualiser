# Network Attack Visualiser — frontend example environment.
#
# Copy to `.env` (git-ignored) to override. Only VITE_-prefixed variables are
# exposed to the browser bundle by Vite. This file contains NO secrets: the
# dashboard is read-only and never holds the sensor ingest token.
#
#     cp .env.example .env

# Base URL of the Phase 3 backend REST API. The WebSocket URL is derived from
# this by swapping the scheme (http -> ws, https -> wss). The default works for
# both local development and the future Phase 6 loopback-published lab, because
# the browser always reaches the backend on host loopback.
VITE_API_BASE_URL=http://localhost:8000
